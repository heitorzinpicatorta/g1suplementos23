# ══════════════════════════════════════════════════════════
#  .env  —  G1 Suplementos
#  Copie para .env e preencha com seus valores reais
#  NUNCA envie o .env real para o Git!
# ══════════════════════════════════════════════════════════

# ── Mercado Pago ─────────────────────────────────────────────
# Access Token do backend (começa com APP_USR- em produção ou TEST- em sandbox)
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Public Key (usada no front-end para o SDK JS do MP)
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Admin — APENAS variáveis sem VITE_ ───────────────────────
# Estas NÃO vão para o bundle JS do Vite — ficam só no servidor
ADMIN_USER=admin
ADMIN_PASS=sua-senha-forte-aqui

# ── Servidor ─────────────────────────────────────────────────
PORT_SERVER=3001

# URL do front-end (usada em CORS e em back_urls do Mercado Pago)
FRONTEND_URL=http://localhost:5173

# Nome exibido na fatura do cartão
STORE_NAME=G1 Suplementos
