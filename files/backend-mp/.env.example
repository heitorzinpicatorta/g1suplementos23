# ══════════════════════════════════════════════════════════
#  .env  —  Backend Mercado Pago
#  Copie este arquivo para .env e preencha com suas chaves
#  NUNCA envie o .env real para o Git!
# ══════════════════════════════════════════════════════════

# ─── Mercado Pago ──────────────────────────────────────────
# Pegue em: https://www.mercadopago.com.br/developers/panel/app
#
# ATENÇÃO: use as chaves de TESTE primeiro (começam com TEST-)
#          e só troque pelas de PRODUÇÃO quando for ao ar.

MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Public Key (usada no FRONT-END para inicializar o SDK JS do MP)
# Coloque também no .env do Vite como VITE_MP_PUBLIC_KEY
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Servidor ──────────────────────────────────────────────
PORT=3001

# URL do seu front-end (para CORS e back_urls do Checkout Pro)
FRONTEND_URL=http://localhost:5173

# Nome que aparece na fatura do cartão
STORE_NAME=Minha Loja de Suplementos
